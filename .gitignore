backup/
.backups/
backups/*.tar.gz

# HA storage / cloud
.cloud/
.storage/

# TTS cache
tts/

# Python caches
__pycache__/
*.pyc

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local repo-audit helper script
scripts/check-repo-config.sh
_private/forum-post.md
