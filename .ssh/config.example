# SSH Configuration for GitHub Access
# Copy this file to /config/.ssh/config and ensure proper permissions:
#   chmod 600 /config/.ssh/config
#   chmod 700 /config/.ssh/

Host github.com
    HostName github.com
    User git
    IdentityFile /config/.ssh/id_ed25519
    # Enforce host key verification (recommended)
    StrictHostKeyChecking yes
    # Known hosts file. Seed it first with:
    # ssh-keyscan -t ed25519 github.com >> /config/.ssh/known_hosts
    UserKnownHostsFile /config/.ssh/known_hosts
    # Connection settings
    IdentitiesOnly yes
    # Increase timeout for slow connections
    ConnectTimeout 10
