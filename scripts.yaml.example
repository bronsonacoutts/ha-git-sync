# scripts.yaml — Git Sync HA Scripts Snippet
#
# Add this to your /config/scripts.yaml (create the file if it doesn't exist).
# Ensure configuration.yaml contains:  script: !include scripts.yaml

maintenance_git_push_config:
  alias: "[Maintenance] Git Push Config"
  description: >-
    Debounced push: waits 3 minutes after the last lovelace change before
    committing and pushing. Rapid edits are batched into one commit.
  sequence:
    - delay: "00:03:00"
    - action: shell_command.git_push
  mode: restart

maintenance_git_sync_config:
  alias: "[Maintenance] Git Sync Config"
  description: "Pull then push — used by the reload automation trigger."
  sequence:
    - action: shell_command.git_pull
    - action: shell_command.git_push
  mode: single
